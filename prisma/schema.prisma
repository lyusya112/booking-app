generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Booking {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  service   String
  date      String
  time      String
  comment   String?
  status String @default("new")
  createdAt DateTime @default(now())
}